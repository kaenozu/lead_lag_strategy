# 日米業種リードラグ戦略 - 環境変数設定

# ============================================
# サーバー設定
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# バックテスト設定
# ============================================
# ウィンドウ長（日数）
WINDOW_LENGTH=60

# 因子数
N_FACTORS=3

# 正則化パラメータ（0.0 - 1.0）
LAMBDA_REG=0.9

# 分位点（0.1 - 0.5）
QUANTILE=0.3

# ウォームアップ期間（日数）
WARMUP_PERIOD=60

# Web /api/backtest の Yahoo chart 取得（カレンダー日数）
BACKTEST_CHART_DAYS=2000

# バックテスト取引コスト（backtest_real / analysis と同系、applyTransactionCosts で×2）
BACKTEST_SLIPPAGE=0.001
BACKTEST_COMMISSION=0.0005

# 年次 R/R 補助のローリング窓（営業日）
BACKTEST_ROLLING_WINDOW=252

# ============================================
# データ設定
# ============================================
# データ取得開始日
START_DATE=2018-01-01

# データ取得終了日
END_DATE=2025-12-31

# データディレクトリ
DATA_DIR=./data

# データソース: yahoo（近似）| csv（DATA_DIR の CSV を優先・再現用）
BACKTEST_DATA_MODE=yahoo

# 推定ウィンドウ内の日本側リターン: cc | oc（P&L の翌営業日 OC は別系列のまま）
BACKTEST_JP_WINDOW_RETURN=cc

# 結果出力ディレクトリ
OUTPUT_DIR=./results

# ============================================
# 取引設定
# ============================================
# 初期資金（円）
INITIAL_CAPITAL=1000000

# 手数料率
COMMISSION_RATE=0.0003

# スリッページ率
SLIPPAGE_RATE=0.0005

# 最大ポジションサイズ（総資金に対する割合）
MAX_POSITION_SIZE=0.1

# 最大総エクスポージャー（総資金に対する割合）
MAX_TOTAL_EXPOSURE=0.6

# ============================================
# ログ設定
# ============================================
# ログレベル（error, warn, info, debug）
LOG_LEVEL=info

# ログファイルパス（省略時はコンソールのみ）
# LOG_FILE=./logs/app.log

# ============================================
# Yahoo Finance設定
# ============================================
# リクエストタイムアウト（ミリ秒）
YF_TIMEOUT=30000

# リトライ回数
YF_RETRIES=3
