# 日米業種リードラグ戦略 - 環境変数設定
#
# 読み込み順: システム env → リポジトリ直下の .env → .env.local（最優先）。パスは cwd ではなくプロジェクトルート基準です。
# データ取得モード（日本 yahoo/jquants/csv・米国 yahoo/alphavantage）は Web 画面または config/runtime-data-source.json（gitignore）
#   例: cp config/runtime-data-source.json.example config/runtime-data-source.json
# 機密（API キー・パスワード・トークン）はリポジトリにコミットしないこと。
#   推奨: .env.local にだけ書く（.gitignore 済み）または OS で設定
#   PowerShell 例: $env:ALPHA_VANTAGE_API_KEY = "your_key"
#   bash 例:       export ALPHA_VANTAGE_API_KEY=your_key
#
# --- 外部 API（機密・任意）---
# Alpha Vantage: 既定キー名 ALPHA_VANTAGE_API_KEY。ALPHAVANTAGE_API_KEY / AV_API_KEY / ALPHA_VANTAGE_KEY も同じ用途で読みます。
# 無料枠は TIME_SERIES_DAILY の outputsize=full が使えないため既定は compact（直近約100営業日）。有料なら full を指定。
# ALPHA_VANTAGE_OUTPUTSIZE=compact
# ALPHA_VANTAGE_API_KEY=
# JQUANTS_API_KEY= または JQUANTS_REFRESH_TOKEN=
# JQUANTS_API_MAIL= / JQUANTS_API_PASSWORD=
# -------------------------------------------

# ============================================
# サーバー設定
# ============================================
PORT=3000
NODE_ENV=development
# 逆プロキシ配下でのクライアントIP解決（レート制限キー用）: 0/false=無効, 1=先頭プロキシを信頼
TRUST_PROXY=0

# ============================================
# バックテスト設定
# ============================================
# ウィンドウ長（日数）
WINDOW_LENGTH=60

# 因子数
N_FACTORS=3

# 正則化パラメータ（0.0 - 1.0）
LAMBDA_REG=0.9

# 分位点（0.1 - 0.5）
QUANTILE=0.4

# ウォームアップ期間（日数）
WARMUP_PERIOD=60

# Web /api/backtest の Yahoo chart 取得（カレンダー日数）
BACKTEST_CHART_DAYS=2000

# バックテスト取引コスト（0＝論文 Table 2 の無摩擦。実務想定なら例: 0.001 / 0.0005）
BACKTEST_SLIPPAGE=0
BACKTEST_COMMISSION=0

# 年次 R/R 補助のローリング窓（営業日）
BACKTEST_ROLLING_WINDOW=252

# ============================================
# データ設定
# ============================================
# データ取得開始日
START_DATE=2010-01-01

# データ取得終了日
END_DATE=2025-12-31

# データディレクトリ
DATA_DIR=./data

# データソース（日本モード・米国プロバイダ）は環境変数ではなく Web 画面 / runtime-data-source.json を使用
# （下記は無視されます。README・.env.example の説明用に残している場合は削除して構いません）
# BACKTEST_DATA_MODE=jquants
# US_OHLCV_PROVIDER=alphavantage
# ALPHA_VANTAGE_API_KEY=
# 1 日の API 呼び出し上限（既定 25。キャッシュヒットは消費しない）
# ALPHA_VANTAGE_DAILY_MAX_CALLS=25
# キャッシュディレクトリ（空なら DATA_DIR/cache/alphavantage）
# ALPHA_VANTAGE_CACHE_DIR=

# jquants モード: Yahoo で上書きする直近の週数（既定 12）
JQUANTS_YAHOO_RECENT_WEEKS=12

# J-Quants 認証（実装は lib/data/jquants.js。未設定・未実装の間は Yahoo にフォールバック）
# JQUANTS_API_MAIL=
# JQUANTS_API_PASSWORD=
# JQUANTS_REFRESH_TOKEN=
# リフレッシュトークン（画面の「APIキー」相当をここに。JQUANTS_REFRESH_TOKEN とどちらか一方で可）
# JQUANTS_API_KEY=
# JQUANTS_API_BASE=https://api.jquants.com/v1
# 銘柄コード上書き JSON（例: {"1617.T":"16170"}）
# JQUANTS_SYMBOL_MAP_JSON=

# 推定ウィンドウ内の日本側リターン: cc | oc（P&L の翌営業日 OC は別系列のまま）
BACKTEST_JP_WINDOW_RETURN=cc

# 結果出力ディレクトリ
OUTPUT_DIR=./results

# ============================================
# 取引設定
# ============================================
# 初期資金（円）
INITIAL_CAPITAL=1000000

# 手数料率
COMMISSION_RATE=0.0003

# スリッページ率
SLIPPAGE_RATE=0.0005

# 最大ポジションサイズ（総資金に対する割合）
MAX_POSITION_SIZE=0.1

# 最大総エクスポージャー（総資金に対する割合）
MAX_TOTAL_EXPOSURE=0.6

# ============================================
# ログ設定
# ============================================
# ログレベル（error, warn, info, debug）
LOG_LEVEL=info

# ログファイルパス（省略時はコンソールのみ）
# LOG_FILE=./logs/app.log

# ============================================
# Yahoo Finance設定
# ============================================
# リクエストタイムアウト（ミリ秒）
YF_TIMEOUT=30000

# リトライ回数
YF_RETRIES=3
