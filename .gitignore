# 依存関係
node_modules/

# 環境設定
.env
.env.local

# Web 画面で保存したデータ取得モード（リポジトリに含めない）
config/runtime-data-source.json

# ログファイル
*.log
server.log

# 結果ファイル（必要に応じて）
results/*.csv
results/*.json
results/*.txt
!results/.gitkeep

# データファイル（必要に応じて）
data/*.csv
data/cache/
!data/.gitkeep

# OS ファイル
.DS_Store
Thumbs.db

# ローカル用の別リポジトリ（誤コミット防止）
pro/

# IDE
.vscode/
.idea/
.cursor/
*.swp
*.swo

# Claude Code
.claude/hooks/audit.log

# テストカバレッジ
coverage/

# ローカルキャッシュ/一時生成物
.eslintcache
.cache/
.nyc_output/
__pycache__/
*.pyc
.pytest_cache/

# Playwright / UI 検証スクリーンショット（.gitkeep は残す）
e2e-artifacts/*
!e2e-artifacts/.gitkeep
playwright-report/
test-results/
