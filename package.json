{
  "name": "lead_lag_strategy",
  "version": "1.0.0",
  "description": "日米業種 ETF のリードラグ戦略（部分空間正則化 PCA）のバックテスト・シグナル生成ツール",
  "main": "backtest.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/kaenozu/lead_lag_strategy.git"
  },
  "scripts": {
    "setup": "node backtest_improved.js",
    "signal": "node generate_signal.js",
    "start": "node server.js",
    "server": "node server.js",
    "analysis": "node analysis.js",
    "doctor": "node doctor.js",
    "doctor:ci": "node doctor.js --light",
    "paper": "node paper_trading.js",
    "paper-trade": "node paper_trading.js",
    "backtest": "node backtest_real.js",
    "test": "node test_unit.js && node --check server.js && node --check backtest_improved.js && node --check backtest_real.js && node --check generate_signal.js && node --check analysis.js && node --check doctor.js && node --check paper_trading.js && npm run doctor:ci && jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "keywords": [
    "trading",
    "strategy",
    "pca",
    "lead-lag",
    "japan-us"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "winston": "^3.17.0",
    "yahoo-finance2": "^3.13.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.51.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  }
}
